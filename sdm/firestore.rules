rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function myDoc() {
      return userDoc(request.auth.uid);
    }

    function myRole() {
      return isSignedIn() ? myDoc().role : 'guest';
    }

    function isApprovedActive() {
      return isSignedIn()
        && myDoc().approvalStatus == 'approved'
        && myDoc().isActive == true;
    }

    function isLeaderPlus() {
      return isApprovedActive() && myRole() in ['leader', 'admin', 'super_admin'];
    }

    function isAdminPlus() {
      return isApprovedActive() && myRole() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isApprovedActive() && myRole() == 'super_admin';
    }

    function hasExplicitRules(name) {
      return name in [
        'users', 'teams', 'cells', 'organization_settings',
        'announcements', 'events', 'bulletins', 'playlists',
        'daily_content', 'audit_logs', 'qt_entries', 'bible_favorites', 'bible_history',
        'prayer_requests', 'notifications', 'worship_favorites'
      ];
    }

    function privilegedUnchanged() {
      let before = resource.data;
      let after = request.resource.data;
      return after.role == before.role
        && after.approvalStatus == before.approvalStatus
        && after.isActive == before.isActive
        && after.teamId == before.teamId
        && after.teamName == before.teamName
        && after.cellId == before.cellId
        && after.cellName == before.cellName
        && after.ministry == before.ministry
        && after.position == before.position
        && after.approvedBy == before.approvedBy
        && after.approvedAt == before.approvedAt
        && after.rejectionReason == before.rejectionReason
        && after.statistics == before.statistics
        && after.createdAt == before.createdAt
        && after.email == before.email;
    }

    function validRoleChange() {
      let after = request.resource.data.role;
      return after == resource.data.role
        || isSuperAdmin()
        || (myRole() == 'admin' && after in ['user', 'member', 'leader', 'admin']);
    }

    function validSelfCreate() {
      let d = request.resource.data;
      return d.role == 'user'
        && d.approvalStatus == 'pending'
        && d.isActive == true
        && d.approvedBy == null
        && d.approvedAt == null;
    }

    function prayerDoc(prayerId) {
      return get(/databases/$(database)/documents/prayer_requests/$(prayerId)).data;
    }

    function canReadPrayer(data) {
      return isApprovedActive()
        && (
          data.visibility == 'church'
          || (data.visibility == 'private' && data.createdBy == request.auth.uid)
          || (data.visibility == 'cell' && myDoc().cellId != null && data.cellId == myDoc().cellId)
          || (data.visibility == 'team' && myDoc().teamId != null && data.teamId == myDoc().teamId)
          || (data.visibility == 'leaders' && isLeaderPlus())
          || isLeaderPlus()
          || data.createdBy == request.auth.uid
        );
    }

    function canManagePrayer(data) {
      return isApprovedActive() && (data.createdBy == request.auth.uid || isLeaderPlus());
    }

    function notificationReadOnlyUpdate() {
      let before = resource.data;
      let after = request.resource.data;
      return after.userId == before.userId
        && after.type == before.type
        && after.audienceType == before.audienceType
        && after.title == before.title
        && after.body == before.body
        && after.link == before.link
        && after.relatedCollection == before.relatedCollection
        && after.relatedId == before.relatedId
        && after.status == before.status
        && after.metadata == before.metadata
        && after.scheduledFor == before.scheduledFor
        && after.sentAt == before.sentAt
        && after.createdAt == before.createdAt
        && after.createdBy == before.createdBy
        && after.isActive == before.isActive;
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isLeaderPlus();
      allow list: if isLeaderPlus();
      allow create: if isOwner(uid) && validSelfCreate();
      allow update: if (isOwner(uid) && privilegedUnchanged())
        || (isLeaderPlus() && validRoleChange());
      allow delete: if isAdminPlus();
    }

    match /teams/{teamId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /cells/{cellId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /organization_settings/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /announcements/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /events/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /bulletins/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /playlists/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /worship_favorites/{docId} {
      allow read: if isApprovedActive() && resource.data.userId == request.auth.uid;
      allow create: if isApprovedActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isApprovedActive() && resource.data.userId == request.auth.uid;
    }

    match /daily_content/{docId} {
      allow read: if isApprovedActive();
      allow write: if isAdminPlus();
    }

    match /qt_entries/{docId} {
      allow read: if isApprovedActive()
        && (resource.data.userId == request.auth.uid
          || resource.data.visibility in ['cell', 'team', 'church', 'leaders', 'admin']);
      allow create: if isApprovedActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isApprovedActive() && resource.data.userId == request.auth.uid;
    }

    match /bible_favorites/{docId} {
      allow read, write: if isApprovedActive() && resource.data.userId == request.auth.uid;
      allow create: if isApprovedActive() && request.resource.data.userId == request.auth.uid;
    }

    match /bible_history/{docId} {
      allow read, write: if isApprovedActive() && resource.data.userId == request.auth.uid;
      allow create: if isApprovedActive() && request.resource.data.userId == request.auth.uid;
    }

    match /prayer_requests/{prayerId} {
      allow get, list: if canReadPrayer(resource.data);
      allow create: if isApprovedActive()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update, delete: if canManagePrayer(resource.data);

      match /comments/{commentId} {
        allow get, list: if canReadPrayer(prayerDoc(prayerId));
        allow create: if isApprovedActive()
          && canReadPrayer(prayerDoc(prayerId))
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isApprovedActive()
          && (resource.data.createdBy == request.auth.uid || isLeaderPlus());
      }

      match /likes/{uid} {
        allow get, list: if canReadPrayer(prayerDoc(prayerId));
        allow create, delete: if isApprovedActive()
          && canReadPrayer(prayerDoc(prayerId))
          && uid == request.auth.uid;
        allow update: if false;
      }
    }

    match /notifications/{docId} {
      allow get, list: if isApprovedActive()
        && (resource.data.userId == request.auth.uid || isLeaderPlus());
      allow create, delete: if isAdminPlus();
      allow update: if isAdminPlus()
        || (isApprovedActive()
          && resource.data.userId == request.auth.uid
          && notificationReadOnlyUpdate());
    }

    match /audit_logs/{logId} {
      allow read: if isAdminPlus();
      allow create: if isLeaderPlus();
      allow update, delete: if false;
    }

    match /{collection}/{docId} {
      allow read: if isApprovedActive();
      allow write: if isLeaderPlus() && !hasExplicitRules(collection);
    }
  }
}
